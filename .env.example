# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe Configuration (Test or Live Mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Stripe Price IDs (From Product Catalog -> CVio Pro -> Price details)
STRIPE_PRO_MONTHLY_PRICE_ID=price_your_monthly_price_id
STRIPE_PRO_ANNUAL_PRICE_ID=price_your_annual_price_id

# App Configuration
NEXT_PUBLIC_URL=http://localhost:3000
# Active Payment Provider ('stripe' or 'iyzico')
NEXT_PUBLIC_PAYMENT_PROVIDER=iyzico

# Iyzico Configuration (If using iyzico instead of Stripe)
IYZICO_API_KEY=your_api_key
IYZICO_SECRET_KEY=your_secret_key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Mock Checkout Secret (Security fallback for local development when keys are missing)
MOCK_CHECKOUT_SECRET=cvio_mock_2024_secret
